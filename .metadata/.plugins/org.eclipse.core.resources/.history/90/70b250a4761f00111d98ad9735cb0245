package com.example;

public class Pyramid {
	static int n = 5;
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		
		// for rows
		for(int i =1;i<=n;i++) {
			// for space
			for(int s = 1; s<= 2*(n-i);s++) {
				System.out.print(" ");
			}
			// for stars
			for(int j=1;j<= 2*i-1;j++) {
				System.out.print("* ");
			}
			System.out.println();
		}

	}

}
