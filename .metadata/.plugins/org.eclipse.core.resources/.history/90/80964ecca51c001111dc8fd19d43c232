package com.example;

import java.util.Scanner;

public class LeftAngleStarPattern {

	public static void main(String[] args) {
		Scanner sc = new Scanner (System.in);
		System.out.println("Enter the value of N:");
		int n = sc.nextInt();
		printLeftAngleStarPattern(n);
		sc.close();

	}
			private static void  printLeftAngleStarPattern(int n) {
				// row loop
				for(int i =1 ; i<= n;i++) {
					
					// space loop
					for(int j=1;j<=(n-i)*2;j++) {
						System.out.print(" ");
					}
					for(int k = 1;k<=i;k++) {
						System.out.println("*");
						}
					System.out.println();
				}
				
			}
}
