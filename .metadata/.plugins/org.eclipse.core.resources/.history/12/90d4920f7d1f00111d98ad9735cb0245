package com.example;

import java.util.Scanner;

public class HollowDiamond {
	static int n =5;
	public static void main(String[] args) {
		Scanner sc = new Scanner (System.in);
		System.out.println("Enter the Value of N:");
		int n = sc.nextInt();
		printHollowDiamond(n);
		sc.close();
	}
		private static void printHollowDiamond(int n) {
		// for upper row
		for(int i= 1;i<=n;i++) {
			//for space
			for(int s=1;s<=2*(n-i);s++) {
				System.out.print(" ");
			}
			// for star
			for(int j=1;j<=2*i-1;j++) {
				if(j==1 ||  j==2*i-1) {
				System.out.print("*");
				} else {
					System.out.print("  ");
				}
				}
			System.out.println();
		}
		
		// for lower part row
		for (int i=1;i<=n-1;i++) {
			//for space
			for(int s=1;s<=2*i;s++) {
				System.out.print(" ");
			}
			// for star
			for(int j=1;j<=2*(n-i)-1;j++) {
				
				if(j==1 || j == 2*(n-i)-1) {
				System.out.print("*");
			}else {
			System.out.print("  ");	
				}
			}
			System.out.println();
		}

	}

}
