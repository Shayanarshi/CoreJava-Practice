package com.example;
import java.util.Scanner;
public class Character {

	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the Value of N:");
		int n = sc.nextInt();
		printCharacter(n);
		sc.close();
		
	}
	
	private static void printCharacter(int n) {
		
		
		char ch = 'A';
		for(int i =1; i<=n; i++) {
			for(int j =1; j<= i; j++) {
				char ch2 = ch;
				System.out.print(ch2+ " ");
				ch--;
			}
			System.out.println();
		}
	}

}
