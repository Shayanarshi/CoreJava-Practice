package com.example;

public class Diamond {
	static int n =5;
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		
		// for upper row
		for(int i= 1;i<=n;i++) {
			//for space
			for(int s=1;s<=2*(n-i);s++) {
				System.out.print(" ");
			}
			// for star
			for(int j=1;j<=2*i-1;j++) {
				System.out.print("* ");
			}
			System.out.println();
		}
		
		// for lower part row
		for (int i=1;i<=n-1;i++) {
			//for space
			for(int s=1;s<=2*i;s++) {
				System.out.print(" ");
			}
			// for star
			for(int j=1;j<=2*(n-i)-1;j++) {
				System.out.print("* ");
			}
			System.out.println();
		}

	}

}
