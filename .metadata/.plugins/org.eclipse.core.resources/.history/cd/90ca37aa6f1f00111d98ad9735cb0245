package com.example;
import java.util.Scanner;
public class Test{
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.println("enter N:");
		int n = sc.nextInt();
		sc.close();
		printPyramid(n);			
	}	
	private static void printPyramid(int n) {
		
		
		for(int i =1;i<=n;i++) {
			for(int s = 1; s<=2*(n-i);s++) {
				System.out.print(" " + " ");
			}
			for(int j =1;j<=2*(i-1);i++) {
				System.out.print("*");
			}
		}
	}

}	