package com.example;

public class HollowSquare {
	static int n =5;
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		// for rows
		for(int i=1;i<=n;i++) {
			// for star
			for(int j=1;j<=n;j++) {
				if(j==1 || j==n || i==1 || i==n) {
				System.out.print("* ");
				}else {
					System.out.print("  ");
				}
			}
			System.out.println();
		}	
	}
}