/**Program: Pascal triangle.
 The edges of each row of the pascal triangle are 1's.
The middle elements of a row are the sum of the
corresponding two elements of the above row.
 if n = 5, **/
package com.example;

import java.util.Scanner;

public class PascalTriangle {

	public static void main(String[] args) {
	
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the Value of N:");
		int n = sc.nextInt();
		printPascalTraingle(n);
		factorial(n);
		sc.close();

	}
	private static void printPascalTraingle(int n) {
		for(int i =0; i<n; i++) {
			// space loop
			for(int s=0;s<n-i+1;s++) {
				System.out.print(" ");
			}
			// number loop
			for(int j=1; j<=i;j++) {
				int num = factorial(i)/(factorial(j) * factorial(i-j));
				System.out.print(num + " ");
			}
			System.out.println();
		}// end of rows loop
		
		
	}
	
	private static int factorial(int i) {
			int result =1;
			for(int  k =1;k<=i;k++)
				result = result * k;
			return result;
			
	}

}
